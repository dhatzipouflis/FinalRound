{
  "ErrorHandling": {
    "IncludeDetailedMessages": true
  },
  "Redis": {
    "ConnectionString": "127.0.0.1:6379",
    "DefaultExpirationMinutes": 10,
    "Namespaces": {
      "Root": "finalround",
      "Shared": "shared",
      "Service": "edge"
    }
  },
  "ServiceInvocation": {
    "Routes": {
      "Tournament.Ping": {
        "RouteToAppId": "finalround-tournament",
        "MethodRoute": "ping",
        "Protocol": "GET"
      },
      "Tournament.Boom": {
        "RouteToAppId": "finalround-tournament",
        "MethodRoute": "boom",
        "Protocol": "GET"
      },
      "Identity.Register": {
        "RouteToAppId": "finalround-identity",
        "MethodRoute": "api/Auth/Register",
        "Protocol": "POST"
      },
      "Identity.Login": {
        "RouteToAppId": "finalround-identity",
        "MethodRoute": "api/Auth/Login",
        "Protocol": "POST"
      },
      "Identity.Refresh": {
        "RouteToAppId": "finalround-identity",
        "MethodRoute": "api/Auth/Refresh",
        "Protocol": "POST"
      },
      "Identity.Logout": {
        "RouteToAppId": "finalround-identity",
        "MethodRoute": "api/Auth/Logout",
        "Protocol": "POST"
      },
      "Identity.Me": {
        "RouteToAppId": "finalround-identity",
        "MethodRoute": "api/Auth/Me",
        "Protocol": "GET"
      }
    }
  }
}
